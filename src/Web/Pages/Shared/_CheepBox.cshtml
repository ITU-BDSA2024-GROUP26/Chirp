@inject SignInManager<Core.Author> SignInManager 
@inject UserManager<Core.Author> UserManager
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@model string

@if (SignInManager.IsSignedIn(User))
{
    <div class="cheepbox">
    <h3>What's on your mind, @Model</h3>
    <form method="post" asp-page-handler="Share" onsubmit="playSound()">
        <input type="text" name="Message" required>
        <input type="submit" value="Share">
    </form>
    <audio id="sendSound" src="sounds/mixkit-fast-small-sweep-transition-166.mp3" preload="auto" volume="1.0"></audio>
    </div>
}

@section Scripts {
    <script>
        function playSound() {
            var sound = document.getElementById('sendSound');
            sound.play();
        }
    </script>
}
